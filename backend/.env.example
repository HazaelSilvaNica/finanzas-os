# ─────────────────────────────────────────────────────────────
#  FinanzasOS — Variables de Entorno
#  Copia este archivo como ".env" y rellena los valores reales.
#  NUNCA subas el archivo .env a Git o lo compartas.
# ─────────────────────────────────────────────────────────────

# URL base de tu instancia Odoo (sin barra final)
ODOO_URL=https://electriganadero.odoo.com

# Nombre de la base de datos en Odoo
ODOO_DB=electriganadero

# API Key de Odoo
# Para generarla: Odoo → Mi Perfil → Seguridad → Nuevo Token de API
# ⚠️  Déjalo vacío hasta que estés listo. El servidor arranca sin ella,
#     pero los endpoints financieros devolverán 503 hasta que la configures.
ODOO_API_KEY=

# Modo de operación (solo documentación — el código refuerza esto internamente)
ODOO_YOLO=read
